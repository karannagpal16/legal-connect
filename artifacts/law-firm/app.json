{
  "expo": {
    "name": "Legal Connect",
    "slug": "legal-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "legalconnect",
    "userInterfaceStyle": "dark",
    "entryPoint": "./src/index.native.tsx",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/images/law-library-bg.png",
        "backgroundColor": "#1e1e2e"
      },
      "package": "com.legalconnect.app"
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.legalconnect.app"
    },
    "web": {
      "favicon": "./public/images/law-library-bg.png",
      "output": "static"
    },
    "splash": {
      "image": "./public/images/law-library-bg.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1e2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      "expo-splash-screen",
      "expo-router"
    ],
    "primaryColor": "#4169E1"
  }
}
